# Market Loom environment configuration
# Copy this file to .env in the project root for local use only.

# ── Tushare ──────────────────────────────────────────────────────────────────
# Obtain your token from https://tushare.pro/user/token after registration.
# 2000 credits enables the default Stage-1 dataset list (daily bars, adj_factor,
# stk_limit, suspend_d, index data, SW2021 industry history).
# 5000 credits unlocks fundamentals: fina_indicator, income, balancesheet,
# cashflow, forecast, express. Set those datasets to enabled = true in
# config/data_sources.toml after upgrading.
TUSHARE_TOKEN=your_token_here

# ── Free fallbacks ────────────────────────────────────────────────────────────
# AKShare: free, covers daily price and index_daily only.
# Used automatically when TUSHARE_TOKEN is empty or a dataset is not supported.
AKSHARE_FALLBACK=true

# Baostock: free, covers daily price only.  Disabled by default.
BAOSTOCK_FALLBACK=false
